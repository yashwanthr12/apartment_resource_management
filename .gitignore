# ============================================================
# ApartEase — Git Ignore Specifications
# ============================================================

# ── 1. Environments & Credentials ──
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
venv/
env/
ENV/
*.env

# ── 2. Python / Backend Junk ──
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/
pip-selfcheck.json
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── 3. Node.js & React Frontend ──
node_modules/
frontend/node_modules/
jspm_packages/
.npm
.eslintcache
.stylelintcache
frontend/dist/
frontend/build/
static/react/

# ── 4. Uploads & Temporary Media ──
static/uploads/*
!static/uploads/.gitkeep
*.receipt
*.pdf

# ── 5. IDEs & Editors ──
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.settings/

# ── 6. OS & Log Files ──
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── 7. Testing & Coverage ──
.cache/
.pytest_cache/
.coverage
htmlcov/
.nyc_output/